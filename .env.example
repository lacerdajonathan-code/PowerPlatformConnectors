# Microsoft Graph API Authentication
# Get these values from Azure AD App Registration

# Azure AD Tenant ID
TENANT_ID=your-tenant-id-here

# Application (client) ID
CLIENT_ID=your-client-id-here

# Client Secret (Application Password)
CLIENT_SECRET=your-client-secret-here

# Or use a pre-obtained access token for testing
GRAPH_ACCESS_TOKEN=your-access-token-here

# Required API Permissions (Microsoft Graph):
# - Files.ReadWrite.All (for Excel access)
# - Group.ReadWrite.All (for Planner access)
# - Tasks.ReadWrite (for Planner tasks)